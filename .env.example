# Server
WHATSAR_PORT=8080
WHATSAR_HOST=127.0.0.1
# URL publik (opsional) — kosongkan = otomatis dari domain
# WHATSAR_PUBLIC_URL=https://whatsar.dev

# Database
WHATSAR_DB_PATH=./data/whatsar.db

# Auth (ganti di production!)
WHATSAR_API_KEY=change-me-to-random-key
WHATSAR_ADMIN_PASSWORD=change-me

# Sessions — 0 = tanpa batas
WHATSAR_MAX_SESSIONS=5

# Log
WHATSAR_LOG_LEVEL=info